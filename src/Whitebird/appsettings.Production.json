{
  "Cors": {
    "AllowedOrigins": [
      "https://app.whitebird.com",
      "https://admin.whitebird.com"
    ]
  },
  "DatabaseSettings": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 5,
    "EnableDetailedErrors": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  }
}